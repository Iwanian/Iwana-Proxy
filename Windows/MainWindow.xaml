<Window x:Class="IwanaProxy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="Iwana Proxy" Height="680" Width="420"
        MinHeight="500" MinWidth="360"
        Icon="Assets/icon.ico"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Settings / icon button -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource IconButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary blue button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Copy / small outline button -->
        <Style x:Key="CopyButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource IconButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Big scan / refresh bottom button -->
        <Style x:Key="ScanButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- channel banner -->
            <RowDefinition Height="*"/>
            <!-- list -->
            <RowDefinition Height="Auto"/>
            <!-- scan button -->
        </Grid.RowDefinitions>

        <!-- ══════════════ HEADER ══════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" Padding="16,14,16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Settings gear -->
                <Button Grid.Column="0" x:Name="SettingsBtn" Content="⚙" Style="{StaticResource IconButton}"
                        VerticalAlignment="Center" Click="SettingsButton_Click"/>

                <!-- Title + status (right aligned like screenshot) -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Iwana Proxy"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                        <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource AliveBrush}"/>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════ CHANNEL BANNER ══════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource Card2Brush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="ChannelBtn"
                        Content="I_w_a_n_a@"
                        Style="{StaticResource PrimaryButton}"
                        Click="ChannelButton_Click"
                        Margin="0,0,12,0"/>

                <TextBlock Grid.Column="1" x:Name="FollowText" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center">
                    🙏 Please follow us on Telegram @I_w_a_n_a
                </TextBlock>
            </Grid>
        </Border>

        <!-- ══════════════ PROXY LIST ══════════════ -->
        <ListBox x:Name="ProxyList" Grid.Row="2"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="10,8,10,0"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="14,12">
                        <StackPanel>
                            <!-- Top row: status badge + proxy name + copy -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Proxy number and IP:Port -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="Proxy #"/><Run Text="{Binding Id}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ServerDisplay}"
                                               FontSize="12" FontFamily="Consolas"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>

                                <!-- ONLINE / OFFLINE badge -->
                                <Border Grid.Column="1" CornerRadius="4" Padding="8,3" Margin="8,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource PingBgDeadBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource PingBgAliveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AliveBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Copy button -->
                                <Button Grid.Column="2" Content="⧉" Style="{StaticResource CopyButton}"
                                        Click="CopyButton_Click" Tag="{Binding}"
                                        VerticalAlignment="Center" ToolTip="Copy proxy link"/>
                            </Grid>

                            <!-- Divider -->
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,10,0,10"/>

                            <!-- Bottom row: latency + connect button -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Latency display like screenshot: ms104 LATENCY -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,1">ms</TextBlock>
                                    <TextBlock Text="{Binding PingMs}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlive}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock x:Name="LatencyLabel"
                                               FontSize="9" FontWeight="SemiBold" VerticalAlignment="Bottom"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="4,0,0,2">LATENCY</TextBlock>
                                </StackPanel>

                                <!-- Connect button -->
                                <Button Grid.Column="1" x:Name="ConnectBtn"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="ConnectButton_Click" Tag="{Binding}"
                                        MinWidth="90">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▶  " VerticalAlignment="Center" FontSize="11"/>
                                        <TextBlock x:Name="ConnectLabel" Text="Connect"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ══════════════ SCAN BUTTON ══════════════ -->
        <Border Grid.Row="3" Background="{DynamicResource CardBrush}" Padding="14,12">
            <Button x:Name="ScanBtn" Style="{StaticResource ScanButton}"
                    HorizontalAlignment="Stretch"
                    Click="RefreshButton_Click">
                <TextBlock x:Name="ScanBtnText" Text="⚡  SCAN PROXIES" FontSize="15" FontWeight="Bold"/>
            </Button>
        </Border>
    </Grid>
</Window>
