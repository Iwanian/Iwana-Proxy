<Application x:Class="IwanaProxy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Dark mode defaults (overridden at runtime by ThemeManager) -->
        <SolidColorBrush x:Key="BgBrush"              Color="#0E1621"/>
        <SolidColorBrush x:Key="CardBrush"            Color="#17212B"/>
        <SolidColorBrush x:Key="Card2Brush"           Color="#1E2C3A"/>
        <SolidColorBrush x:Key="AccentBrush"          Color="#2EA6FF"/>
        <SolidColorBrush x:Key="AliveBrush"           Color="#3FCF6E"/>
        <SolidColorBrush x:Key="DeadBrush"            Color="#E5544F"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#F1F1F1"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#8C97A3"/>
        <SolidColorBrush x:Key="InputBgBrush"         Color="#0E1621"/>
        <SolidColorBrush x:Key="DividerBrush"         Color="#1E2C3A"/>
        <SolidColorBrush x:Key="IconButtonHoverBrush" Color="#1F2C38"/>
        <SolidColorBrush x:Key="PingBgAliveBrush"     Color="#1C3A2A"/>
        <SolidColorBrush x:Key="PingBgDeadBrush"      Color="#2A333D"/>
    </Application.Resources>
</Application>
